<Page
    x:Class="RAGDataIngestionWPF.Views.DataGridPage"
    Style="{DynamicResource MahApps.Styles.Page}"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:RAGDataIngestionWPF.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:properties="clr-namespace:RAGDataIngestionWPF.Properties"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <Page.DataContext>
        <vm:DataGridViewModel />
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Style="{StaticResource PageTitleStyle}"
            Text="{x:Static properties:Resources.DataGridPageTitle}" />
        <Grid Grid.Row="1">
            <StackPanel Margin="{StaticResource SmallLeftRightMargin}" HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <StackPanel Orientation="Vertical" Width="250">
                    <Button Margin="3" Content="Start Ingestion" Height="30" Width="175" FontSize="12"
                            Click="Button_Click" />
                    <Button Margin="3" Content="Button 1" Height="30" Width="175" />
                    <Button Margin="3" Content="Button 1" Height="30" Width="175" />
                </StackPanel>
                <StackPanel Orientation="Vertical" Width="300">
                    <Border BorderBrush="#FF999AAF" BorderThickness="1" CornerRadius="5" Background="#FF090C1D"
                            HorizontalAlignment="Center" Padding="3,3,3,3">
                        <StackPanel Orientation="Horizontal">
                            <Label Name="Label1" Content="New" Width="86" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Background="{x:Null}" Foreground="#FFD0D0D0"
                                   FontSize="14" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                   MinHeight="20" />
                            <TextBox Width="85"
                                     AutomationProperties.LabeledBy="{Binding ElementName=Label1, Mode=OneWay}"
                                     VerticalAlignment="Top" MinHeight="20" Background="{x:Null}" Foreground="White"
                                     Text="0" FontSize="14" BorderThickness="0,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#FF999AAF" BorderThickness="1" CornerRadius="5" Background="#FF090C1D"
                            HorizontalAlignment="Center" Padding="3,3,3,3">
                        <StackPanel Orientation="Horizontal">
                            <Label Name="Label2" Content="Error" Width="86" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Background="{x:Null}" Foreground="#FFD0D0D0"
                                   FontSize="14" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                   MinHeight="20" />
                            <TextBox Width="85"
                                     AutomationProperties.LabeledBy="{Binding ElementName=Label2, Mode=OneWay}"
                                     VerticalAlignment="Top" MinHeight="20" Background="{x:Null}" Foreground="White"
                                     Text="0" FontSize="14" BorderThickness="0,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#FF999AAF" BorderThickness="1" CornerRadius="5" Background="#FF090C1D"
                            HorizontalAlignment="Center" Padding="3,3,3,3">
                        <StackPanel Orientation="Horizontal">
                            <Label Name="Label3" Content="Updated" Width="86" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Background="{x:Null}" Foreground="#FFD0D0D0"
                                   FontSize="14" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                   MinHeight="20" />
                            <TextBox Width="85"
                                     AutomationProperties.LabeledBy="{Binding ElementName=Label2, Mode=OneWay}"
                                     VerticalAlignment="Top" MinHeight="20" Background="{x:Null}" Foreground="White"
                                     Text="0" FontSize="14" BorderThickness="0,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Vertical" Width="250" />
            </StackPanel>

        </Grid>
        <Grid Grid.Row="2">
            <DataGrid
                AutoGenerateColumns="False"
                GridLinesVisibility="Horizontal"
                CanUserAddRows="False"
                ItemsSource="{Binding Source}"
                Margin="{StaticResource SmallLeftRightMargin}"
                KeyboardNavigation.TabNavigation="Once">
                <DataGrid.Columns>
                    <!--
                        TODO:
                        Remove this column definitions and define columns for your data.
                        Consider adding header properties to Resources.resw
                    -->
                    <DataGridTextColumn Binding="{Binding OrderID}" Header="OrderID" />
                    <DataGridTextColumn Binding="{Binding OrderDate}" Header="OrderDate" />
                    <DataGridTextColumn Binding="{Binding Company}" Header="Company" />
                    <DataGridTextColumn Binding="{Binding ShipTo}" Header="ShipTo" />
                    <DataGridTextColumn Binding="{Binding OrderTotal}" Header="OrderTotal" />
                    <DataGridTextColumn Binding="{Binding Status}" Header="Status" />
                    <DataGridTemplateColumn Header="Symbol">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="{StaticResource SmallLeftRightMargin}"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SmallIconStyle}"
                                    Text="{Binding Symbol}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>