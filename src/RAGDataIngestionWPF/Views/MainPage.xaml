<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="clr-namespace:RAGDataIngestionWPF.Converters"
    xmlns:mdxam="clr-namespace:MdXaml;assembly=MdXaml"
    xmlns:properties="clr-namespace:RAGDataIngestionWPF.Properties"
    xmlns:models="clr-namespace:RAGDataIngestionWPF.Models"
 
    x:Class="RAGDataIngestionWPF.Views.MainPage"
    Style="{DynamicResource MahApps.Styles.Page}"
    mc:Ignorable="d"
    d:DesignWidth="1000"
    d:DesignHeight="700">

    <Page.Resources>
    </Page.Resources>


    <Grid DataContext="{Binding}">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="0.153" />
                <GradientStop Color="White" Offset="1" />
                <GradientStop Color="#FF292929" Offset="0.293" />
                <GradientStop Color="#FF515151" Offset="0.417" />
                <GradientStop Color="#FF1B1111" Offset="0.567" />
                <GradientStop Color="#FF1D1212" Offset="0.673" />
                <GradientStop Color="#FF231B1B" Offset="0.85" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Style="{StaticResource PageTitleStyle}"
            Text="{x:Static properties:Resources.MainPageTitle}" />
        <Grid
            Grid.Row="1"
            Margin="{StaticResource MediumLeftRightMargin}"
            Background="{DynamicResource MahApps.Brushes.Gray60}">
            <Grid Margin="{StaticResource SmallTopBottomMargin}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="733*" />
                    <ColumnDefinition Width="19*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.ColumnSpan="3" Orientation="Horizontal" >
                <TextBlock Margin="12,0,0,6" Style="{StaticResource BodyTextStyle}" Text="{Binding TotalTokenCount, StringFormat=Total tokens: \{0\} / 130000}" />
                <TextBlock Margin="12,0,0,6" Style="{StaticResource BodyTextStyle}" Text="{Binding SessionTokenCount, StringFormat=Chat tokens: \{0\} / 100000}" />
                <TextBlock Margin="12,0,0,6" Style="{StaticResource BodyTextStyle}" Text="{Binding SystemTokenCount, StringFormat=System tokens: \{0\} / 5000}" />
                <TextBlock Margin="12,0,0,6" Style="{StaticResource BodyTextStyle}" Text="{Binding RagTokenCount, StringFormat=Rag tokens: \{0\} / 10000}" />
                <TextBlock Margin="12,0,0,6" Style="{StaticResource BodyTextStyle}" Text="{Binding ToolTokenCount, StringFormat=Tool tokens: \{0\} / 3000}" />
                </StackPanel>
                <ListBox Grid.Row="1" Grid.Column="0"
                         x:Name="MessagesListBox"
                         Margin="6,0,6,0"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemsSource="{Binding Messages}"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.CanContentScroll="False"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" IsManipulationEnabled="True"
                         SelectionMode="Multiple">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:MessageDisplay}">
                            <Border
                                Margin="0,4"
                                Padding="10"
                                MaxWidth="{Binding ElementName=MessagesListBox, Path=ActualWidth}"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource MahApps.Brushes.Gray8}">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                <Setter Property="Background"
                                                        Value="{DynamicResource MahApps.Brushes.Gray6}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding Role}" />
                                    <mdxam:MarkdownScrollViewer x:Name="mdScroller"
                                                                Margin="0,6,0,0"
                                                                HorizontalAlignment="Stretch"
                                                                IsSelectionEnabled="True"
                                                                BorderBrush="BlanchedAlmond" Markdown="{Binding Text}"
                                                                MarkdownStyleName="DocumentStyleCompact" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,6,0"
                        Padding="12"
                        Background="{DynamicResource MahApps.Brushes.Gray8}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Agent Task Plans" />

                        <ListBox Grid.Row="1"
                                 Margin="0,12,0,12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemsSource="{Binding TaskPlans}"
                                 SelectedItem="{Binding SelectedTaskPlan}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TaskPlanDisplayItem}">
                                    <Border Margin="0,0,0,8"
                                            Padding="8"
                                            Background="{DynamicResource MahApps.Brushes.Gray6}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding PlanName}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding Status, StringFormat=Status: \{0\}}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="{Binding CurrentStep}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="{Binding ArtifactSummary}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Opacity="0.75"
                                                       Text="{Binding UpdatedAt}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2"
                                Padding="8"
                                Background="{DynamicResource MahApps.Brushes.Gray6}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Selected Plan" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SelectedTaskPlan.PlanName, TargetNullValue=No task plans recorded}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="{Binding SelectedTaskPlan.Status, StringFormat=Status: \{0\}}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="{Binding SelectedTaskPlan.CurrentStep}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Grid.Column="0" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             MinHeight="82"
                             Margin="0,0,8,0"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             KeyDown="UIElement_OnKeyDown"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black" />
                                <GradientStop Color="White" Offset="1" />
                                <GradientStop Color="#FF282828" Offset="0.16" />
                                <GradientStop Color="#FF404040" Offset="0.257" />
                                <GradientStop Color="#FF191212" Offset="0.327" />
                            </LinearGradientBrush>
                        </TextBox.Background>
                    </TextBox>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Vertical">
                        <Button
                            x:Name="SendBtn"
                            Margin="8,0,0,8"
                            MinWidth="96"
                            Command="{Binding SendMessageCommand}"
                            Content="Send" />
                        <Button
                            Margin="8,0,0,0"
                            MinWidth="96"
                            IsCancel="True"
                            Command="{Binding CancelMessageCommand}"
                            Content="Cancel" />
                    </StackPanel>

                    <ProgressBar
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,8,0,0"
                        Height="35"
                        HorizontalAlignment="Stretch"
                        IsIndeterminate="True"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Orientation="Horizontal" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>